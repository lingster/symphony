# Linear API credentials (at least one of AGENT_TOKEN or API_KEY is required)

# Option 1: OAuth bot/agent token (preferred for automated workflows)
LINEAR_AGENT_TOKEN=lin_oauth_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Option 2: Personal API key (simpler setup, uses your personal identity)
LINEAR_API_KEY=lin_api_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OAuth token refresh (optional, enables automatic token renewal when using AGENT_TOKEN)
LINEAR_OAUTH_CLIENT_ID=your_oauth_client_id
LINEAR_OAUTH_CLIENT_SECRET=your_oauth_client_secret
LINEAR_REFRESH_TOKEN=your_refresh_token
